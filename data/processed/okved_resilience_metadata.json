    "data/processed/okved_resilience_block_scores_2024.csv",
    "data/processed/okved_resilience_ranking_2024.csv",
    "data/processed/okved_resilience_weights_2024.csv",
    "data/processed/okved_resilience_robustness_checks.csv",
